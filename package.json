{
  "name": "@l4n3/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "test:projects": "vitest run",
    "test:projects:watch": "vitest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "docs:generate": "pnpm --filter @l4n3/docs typedoc",
    "docs:dev": "pnpm --filter @l4n3/docs dev",
    "docs:build": "pnpm --filter @l4n3/zodgen build && pnpm docs:generate && pnpm --filter @l4n3/docs build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@l4n3/biome-config": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.20",
    "vitest": "^3.2.1"
  }
}
