{
  "name": "@l4n3/fakeish-gen-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core generator primitives for @l4n3 data generation libraries",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/l4n3-labs/nodejs.git",
    "directory": "packages/fakeish-gen-core"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolve": {
      "types": "./dist/resolve.d.ts",
      "import": "./dist/resolve.js"
    },
    "./generators/string": {
      "types": "./dist/generators/string.d.ts",
      "import": "./dist/generators/string.js"
    },
    "./generators/number": {
      "types": "./dist/generators/number.d.ts",
      "import": "./dist/generators/number.js"
    }
  },
  "scripts": {
    "build": "tsgo --build",
    "check": "tsgo --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "@faker-js/faker": ">=9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@faker-js/faker": "^9.0.0",
    "@l4n3/biome-config": "workspace:*",
    "@l4n3/tsconfig": "workspace:*",
    "@l4n3/vitest-config": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev",
    "vitest": "^3.2.1"
  }
}
