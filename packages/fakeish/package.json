{
  "name": "@l4n3/fakeish",
  "version": "0.2.0",
  "type": "module",
  "description": "Schema-driven fake data generation with Zod and Faker.js",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/l4n3-labs/nodejs.git",
    "directory": "packages/fakeish"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./formats": {
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsgo --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@l4n3/fakeish-gen-core": "workspace:*"
  },
  "peerDependencies": {
    "@faker-js/faker": ">=9.0.0",
    "zod": ">=4.0.0-beta.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@faker-js/faker": "^9.0.0",
    "@l4n3/biome-config": "workspace:*",
    "@l4n3/tsconfig": "workspace:*",
    "@l4n3/vitest-config": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "vitest": "^3.2.1",
    "zod": "^4.0.0-beta.0"
  }
}
